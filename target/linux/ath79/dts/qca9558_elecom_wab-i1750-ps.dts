#include "qca955x.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/delete-node/ &wdt;

/ {
	model = "ELECOM WAB-I1750-PS";
	compatible = "elecom,wab-i1750-ps", "qca,qca9558";

	aliases {
		serial1 = &hsuart;
		label-mac-device = &eth0;

		led-boot = &led_status_red;
		led-failsafe = &led_status_red;
		led-running = &led_status_red;
		led-upgrade = &led_status_red;
	};

	beeper {
		compatible = "gpio-beeper";
		gpios = <&gpio 4 GPIO_ACTIVE_HIGH>;
	};

	keys {
		compatible = "gpio-keys";

		eject {
			label = "eject";
			gpios = <&gpio 19 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_EJECTCD>;
		};

		reset {
			label = "reset";
			gpios = <&gpio 18 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};

		wps {
			label = "wps";
			gpios = <&gpio 16 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};
	};

	leds {
		compatible = "gpio-leds";

		2ghz {
			label = "green:2ghz";
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
		};

		led_status_red: status {
			label = "red:status";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
		};

		usb {
			label = "green:usb";
			gpios = <&gpio 15 GPIO_ACTIVE_LOW>;
		};
	};

	watchdog {
		compatible = "linux,wdt-gpio";
		gpios = <&gpio 12 GPIO_ACTIVE_HIGH>;
		hw_algo = "toggle";
		hw_margin_ms = <300>;
		always-running;
	};
};

&uart {
	status = "okay";
};

&usb_phy0 {
	status = "okay";
};

&gpio {
	hs_uart_input {
		gpio-hog;
		gpios = <1 GPIO_ACTIVE_HIGH>,
			<3 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "highspeed-uart-input";
	};

	hs_uart_output {
		gpio-hog;
		gpios = <0 GPIO_ACTIVE_HIGH>,
			<2 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "highspeed-uart-output";
	};

	usb_power {
		gpio-hog;
		gpios = <11 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-power";
	};
};

&pinmux {
	hs_uart_function: hs_uart_function {
		pinctrl-single,bits = <0x0 0x00130012 0x00ff00ff>;
	};

	hs_uart_pins: hs_uart_pins {
		pinctrl-single,bits = <0x3c 0x03010000 0xffff0000>;
	};
};

&pcie0 {
	status = "okay";

	wifi@0,0 {
		compatible = "qcom,ath10k";

		reg = <0x0000 0 0 0 0>;
		ieee80211-freq-limit = <5170000 5710000>;
	};
};

&wmac {
	status = "okay";

	ieee80211-freq-limit = <2400000 2483000>;
	qca,no-eeprom;
};

&hsuart {
	status = "okay";

	pinctrl-0 = <&hs_uart_function &hs_uart_pins &jtag_disable_pins>;
	pinctrl-names = "default";
};

&usb0 {
	status = "okay";
};

&spi {
	status = "okay";

	num-cs = <1>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
		m25p,fast-read;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x0000000 0x0040000>;
				read-only;
			};

			partition@40000 {
				label = "u-boot-env";
				reg = <0x0040000 0x0010000>;
				read-only;
			};

			art: partition@50000 {
				label = "art";
				reg = <0x0050000 0x0010000>;
				read-only;
			};

			partition@60000 {
				label = "ART2";
				reg = <0x0060000 0x0010000>;
				read-only;
			};

			partition@70000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x0070000 0x0e00000>;
			};

			partition@e70000 {
				label = "manufacture";
				reg = <0x0e70000 0x0100000>;
				read-only;
			};

			partition@f70000 {
				label = "backup";
				reg = <0x0f70000 0x0010000>;
				read-only;
			};

			partition@f80000 {
				label = "storage";
				reg = <0x0f80000 0x0080000>;
				read-only;
			};
		};
	};
};

&mdio0 {
	status = "okay";

	phy4: ethernet-phy@4 {
		reg = <4>;
	};
};

&eth0 {
	status = "okay";

	phy-mode = "rgmii-rxid";
	phy-handle = <&phy4>;

	pll-data = <0xae000000 0x80000101 0x80001313>;

	gmac-config {
		device = <&gmac>;

		rgmii-enabled = <1>;
		ge0-sgmii = <0>;
		txen-delay = <0>;
		txd-delay = <0>;
		rxdv-delay = <3>;
		rxd-delay = <3>;
	};
};

&mdio1 {
	status = "okay";

	phy1: ethernet-phy@1 {
		reg = <1>;
	};
};

&eth1 {
	status = "okay";

	phy-mode = "sgmii";
	phy-handle = <&phy1>;

	pll-data = <0x03000000 0x00000101 0x00001313>;
};
