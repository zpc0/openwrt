/dts-v1/;

#include "mt7622.dtsi"
#include "mt6380.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "I-O DATA WN-TX4266GR";
	compatible = "iodata,wn-tx4266gr", "mediatek,mt7622";

	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	keys {
		compatible = "gpio-keys";

		pinctrl-0 = <&key_pins>;
		pinctrl-names = "default";

		repeater_on {
			label = "repeater_on";
			gpios = <&pio 5 GPIO_ACTIVE_LOW>;
			linux,code = <BTN_0>;
			linux,input-type = <EV_SW>;
		};

		reset {
			label = "reset";
			gpios = <&pio 0 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};

		wps {
			label = "wps";
			gpios = <&pio 22 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};
	};

	leds {
		compatible = "gpio-leds";

		power {
			label = "white:power";
			gpios = <&pio 3 GPIO_ACTIVE_LOW>;
		};

		wps {
			label = "blue:wps";
			gpios = <&pio 4 GPIO_ACTIVE_LOW>;
		};
	};

	reg_1v8: fixed-regulator {
		compatible = "regulator-fixed";
		regulator-name = "reg_1v8";
		regulator-always-on;
		regulator-max-microvolt = <1800000>;
		regulator-min-microvolt = <1800000>;
	};

	reg_3v3: fixed-regulator {
		compatible = "regulator-fixed";
		regulator-name = "reg_3v3";
		regulator-always-on;
		regulator-max-microvolt = <3300000>;
		regulator-min-microvolt = <3300000>;
	};
};

&cpu0 {
	proc-supply = <&mt6380_vcpu_reg>;
	sram-supply = <&mt6380_vm_reg>;
};

&cpu1 {
	proc-supply = <&mt6380_vcpu_reg>;
	sram-supply = <&mt6380_vm_reg>;
};

&pwrap {
	status = "okay";
};

&uart0 {
	status = "okay";
};

&bch {
	status = "okay";
};

&mmc1 {
	status = "okay";

	pinctrl-0 = <&mmc1_pins_default>;
	pinctrl-1 = <&mmc1_pins_uhs>;
	pinctrl-names = "default", "state_uhs";

	bus-width = <4>;
	cap-sd-highspeed;
	cd-gpios = <&pio 81 GPIO_ACTIVE_LOW>;
	max-frequency = <50000000>;

	vmmc-supply = <&reg_1v8>;
	vqmmc-supply = <&reg_1v8>;
};

&wmac {
	status = "okay";

	mediatek,mtd-eeprom = <&factory 0x0>;
};

&pcie0 {
	status = "okay";
};

&slot0 {
	wifi@0,1,0 {
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;

		mediatek,mtd-eeprom = <&factory 0x5000>;
	};
};

&pcie1 {
	status = "okay";
};

&slot1 {
	wifi@1,1,0 {
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;

		mediatek,mtd-eeprom = <&factory 0x10000>;
	};
};

&eth {
	status = "okay";

	gmac0: mac@0 {
		compatible = "mediatek,eth-mac";
		reg = <0>;
		phy-mode = "sgmii";

		mtd-mac-address = <&factory 0x1fe6e>;

		fixed-link {
			speed = <1000>;
			full-duplex;
		};
	};

	/*
	gmac1: mac@1 {
		compatible = "mediatek,eth-mac";
		reg = <1>;
		phy-mode = "rgmii";
	};
	*/

	mdio-bus {
		switch@0 {
			compatible = "mediatek,mt7531";
			#address-cells = <1>;
			#size-cells = <0>;
			reg = <0>;

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;
					label = "lan1";
				};

				port@1 {
					reg = <1>;
					label = "lan2";
				};

				port@2 {
					reg = <2>;
					label = "lan3";
				};

				port@3 {
					reg = <3>;
					label = "lan4";
				};

				port@4 {
					reg = <4>;
					label = "wan";
				};

				/*
				port@5 {
					reg = <5>;
					label = "cpu";
					ethernet = <&gmac1>;
				};
				*/

				port@6 {
					reg = <6>;
					label = "cpu";
					ethernet = <&gmac0>;
				};
			};
		};
	};
};

&pio {
	key_pins: key_pins {
		key {
			pins = "GPIO_A", "I2S_MCLK", "GPIO_B";
			bias-pull-up;
		};
	};

	mmc1_pins_default: mmc1_pins_default {
		mux {
			groups = "sd_0";
			function = "sd";
		};

		clk {
			pins = "I2S3_OUT";
			bias-pull-down;
			drive-strength = <12>;
		};

		cmd_dat {
			pins = "I2S2_IN", "I2S3_IN", "I2S4_IN",
				"I2S2_OUT", "I2S4_OUT";
			bias-pull-up;
			drive-strength = <8>;
			input-enable;
		};

		insert {
			pins = "TXD3";
			bias-pull-up;
		};
	};

	mmc1_pins_uhs: mmc1_pins_uhs {
		mux {
			groups = "sd_0";
			function = "sd";
		};

		clk {
			pins = "I2S3_OUT";
			bias-pull-down;
		};

		cmd_dat {
			pins = "I2S2_IN", "I2S3_IN", "I2S4_IN",
				"I2S2_OUT", "I2S4_OUT";
			bias-pull-up;
			input-enable;
		};

		insert {
			pins = "TXD3";
			bias-pull-up;
		};
	};

	snand_pins: snand_pins {
		clk {
			pins = "SPI_CLK";
			bias-pull-down;
			drive-strength = <8>;
		};

		data {
			pins = "SPI_WP", "SPI_HOLD", "SPI_MOSI",
				"SPI_MISO", "SPI_CS";
			bias-pull-up;
			drive-strength = <8>;
		};
	};
};

&snfi {
	status = "okay";

	pinctrl-names = "default";
	pinctrl-0 = <&snand_pins>;

	flash@0 {
		compatible = "spi-nand";
		reg = <0>;

		mediatek,bmt-v2;
		mediatek,bmt-table-size = <0x1000>;

		partitions {
			#address-cells = <1>;
			#size-cells = <1>;
			compatible = "fixed-partitions";

			partition@0 {
				label = "Preloader";
				reg = <0x0000000 0x0080000>;
				read-only;
			};

			partition@80000 {
				label = "ATF";
				reg = <0x0080000 0x0040000>;
				read-only;
			};

			partition@c0000 {
				label = "Bootloader";
				reg = <0x00c0000 0x0080000>;
				read-only;
			};

			partition@140000 {
				label = "Ubootenv";
				reg = <0x0140000 0x0080000>;
				read-only;
			};

			factory: partition@1c0000 {
				label = "Factory";
				reg = <0x01c0000 0x00c0000>;
				read-only;
			};

			partition@280000 {
				label = "RAS";
				reg = <0x0280000 0x3240000>;
				read-only;
			};

			partition@34c0000 {
				label = "Config";
				reg = <0x34c0000 0x0100000>;
				read-only;
			};

			partition@35c0000 {
				label = "RAS2";
				reg = <0x35c0000 0x3240000>;
				read-only;
			};

			partition@6800000 {
				label = "Config2";
				reg = <0x6800000 0x0100000>;
				read-only;
			};

			partition@6900000 {
				label = "persist";
				reg = <0x6900000 0x0100000>;
				read-only;
			};

			partition@6a00000 {
				label = "idmkey";
				reg = <0x6a00000 0x0100000>;
				read-only;
			};

			partition@6b00000 {
				label = "Backup";
				reg = <0x6b00000 0x0ac0000>;
				read-only;
			};
		};
	};
};
